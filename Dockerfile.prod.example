FROM php:8.4-fpm-bookworm

# Argumentos que podem ser passados no momento do build
ARG user=appuser
ARG uid=1000

# Atualiza pacotes e instala dependências necessárias (Debian)
RUN apt-get update && apt-get install -y \
    curl \
    git \
    libpng-dev \
    libxml2-dev \
    zip \
    unzip \
    libpq-dev \
    libonig-dev \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Instala extensões do PHP para o Laravel e PostgreSQL
RUN docker-php-ext-install pdo pdo_pgsql mbstring exif pcntl bcmath gd

# Copia o Composer mais recente do repositório oficial
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# Cria um usuário não-root para rodar os comandos do Composer e Artisan
RUN useradd -G www-data,root -u $uid -d /home/$user $user \
    && mkdir -p /home/$user/.composer \
    && chown -R $user:www-data /home/$user

# Define o diretório de trabalho
WORKDIR /var/www

# Copia os arquivos do projeto e altera as permissões
COPY . .

# Ajuste de permissões para upload e cache
RUN chown -R $user:www-data /var/www \
    && chmod -R 775 /var/www/storage \
    && chmod -R 775 /var/www/bootstrap/cache

# Configuração de PHP para aceitar arquivos grandes
RUN echo "upload_max_filesize=100M" > /usr/local/etc/php/conf.d/uploads.ini \
    && echo "post_max_size=100M" >> /usr/local/etc/php/conf.d/uploads.ini

# Muda para o usuário sem privilégios
USER $user

# Garante que o diretório de trabalho esteja limpo de caches locais
RUN rm -rf bootstrap/cache/*.php

# Instala as dependências do PHP (sem os pacotes de dev/testes)
RUN composer install --no-dev --optimize-autoloader --no-interaction --no-progress

# Instala pacotes NPM e constrói o Frontend (Vite/Tailwind)
RUN npm install \
    && npm run build

# Expõe a porta padrão do PHP-FPM
EXPOSE 9000

# Executa o PHP-FPM
CMD ["php-fpm"]